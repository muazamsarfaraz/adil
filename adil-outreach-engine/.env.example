# ============================================
# adil-outreach-engine — Environment Variables
# ============================================
# Copy to .env and fill in real values
# Variables marked [REQUIRED] must be set; [OPTIONAL] have sensible defaults.

# --- Service ---
API_KEY=change-me-to-a-secure-random-string          # [REQUIRED]
PORT=8001                                             # [OPTIONAL]

# --- Database ---
# For docker-compose local dev:
DATABASE_URL=postgresql+asyncpg://outreach:outreach_dev@postgres:5432/outreach
# For direct local dev (non-Docker):
# DATABASE_URL=postgresql+asyncpg://outreach:outreach_dev@localhost:5433/outreach

# --- Redis ---
# For docker-compose local dev:
REDIS_URL=redis://redis:6379/0
# For direct local dev (non-Docker):
# REDIS_URL=redis://localhost:6380/0

# --- SendGrid ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx              # [REQUIRED for email]
# Event Webhook ECDSA verification key (delivery, open, click, bounce).
# Pull from SendGrid → Mail Settings → Event Webhook → Signed Event Webhook.
SENDGRID_WEBHOOK_VERIFICATION_KEY=
SENDGRID_WEBHOOK_VERIFY_ENABLED=true
# Inbound Parse webhook bearer token (reply capture). SendGrid Inbound Parse
# does NOT support ECDSA signing — we require a shared secret that SendGrid
# sends in the Parse URL (`?token=...`) OR a fronting proxy injects as
# `Authorization: Bearer ...`. Generate with: `python -c 'import secrets;
# print(secrets.token_urlsafe(32))'`. MUST be set on production deploys —
# the verifier refuses traffic when verify_enabled=true and token="".
SENDGRID_INBOUND_TOKEN=
SENDGRID_INBOUND_VERIFY_ENABLED=true

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx        # [REQUIRED for payments]
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# --- Cal.com ---
CAL_API_KEY=cal_xxxxxxxxxxxxxxxxxxxx                  # [REQUIRED for bookings]
CAL_WEBHOOK_SECRET=your-cal-webhook-secret

# --- LLM Providers ---
# Only needed for providers configured in campaign llm_config
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Optional ---
# DEBUG=false
# LOG_LEVEL=INFO
# PUBLIC_BASE_URL=http://localhost:8001

# --- MSentry central health-bot inbox (optional) ---
# Unset to offboard from MSentry.
MSENTRY_FEEDBACK_URL=
MSENTRY_FEEDBACK_SECRET=
MSENTRY_PROJECT=adil-outreach-engine
