# =============================================================================
# Project Adil - RAG API Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Google Gemini API Key
# -----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/apikey
# 1. Go to the URL above
# 2. Click "Create API Key"
# 3. Copy the key (starts with AIza...)
# 4. Paste below
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# REQUIRED: File Search Store ID
# -----------------------------------------------------------------------------
# This is created AFTER you run the document uploader script.
# 
# Steps:
# 1. First, set up document-uploader/.env with your GEMINI_API_KEY
# 2. Run: cd ../document-uploader && python upload_documents.py
# 3. The script will output a FILE_SEARCH_STORE_ID like: file_search_stores/abc123xyz
# 4. Copy that value here
FILE_SEARCH_STORE_ID=file_search_stores/your_store_id_here

# -----------------------------------------------------------------------------
# REQUIRED: API Key for Authentication
# -----------------------------------------------------------------------------
# All protected endpoints require this key in the X-API-Key header.
# Generate one with: python -c "import uuid; print(f'adil_{uuid.uuid4().hex}')"
ADIL_API_KEY=adil_your_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Allowed CORS Origins (comma-separated)
# -----------------------------------------------------------------------------
# Defaults to the production frontend + localhost if not set.
# ALLOWED_ORIGINS=https://adil-frontend-production.up.railway.app,http://localhost:8000

# -----------------------------------------------------------------------------
# OPTIONAL: Rate Limiting
# -----------------------------------------------------------------------------
# Format: "requests/period" e.g. "30/minute", "100/hour"
# RATE_LIMIT_QUERY=30/minute
# RATE_LIMIT_GENERAL=60/minute

# -----------------------------------------------------------------------------
# OPTIONAL: API Configuration
# -----------------------------------------------------------------------------
# Port to run the API on (default: 8000)
PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# OPTIONAL: Model Selection
# -----------------------------------------------------------------------------
# Default model for queries (gemini-2.5-flash is fast and cheap)
# Use gemini-2.5-pro for complex legal analysis
GEMINI_MODEL=gemini-2.5-flash

# Model for viability scoring (use Pro for accuracy)
GEMINI_MODEL_COMPLEX=gemini-2.5-pro

# Model for image/screenshot analysis (multimodal vision)
GEMINI_MODEL_VISION=gemini-3-flash-preview

# Max image upload size in MB (default: 10)
MAX_IMAGE_SIZE_MB=10

# -----------------------------------------------------------------------------
# OPTIONAL: MSentry central health-bot inbox
# -----------------------------------------------------------------------------
# Unset to offboard from MSentry. Project-local Telegram alerts keep working.
MSENTRY_FEEDBACK_URL=
MSENTRY_FEEDBACK_SECRET=
MSENTRY_PROJECT=adil-rag-api

