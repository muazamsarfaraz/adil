# Meta WhatsApp Cloud API
META_APP_SECRET=                # HMAC-SHA256 webhook signature verification
META_VERIFY_TOKEN=              # Shared secret echoed during subscription verification
META_PHONE_NUMBER_ID=           # Sender phone number ID from Meta dashboard
META_ACCESS_TOKEN=              # System-user token with whatsapp_business_messaging
META_GRAPH_VERSION=v20.0

# Bridge → adil-rag-api
RAG_API_URL=https://askadil.org
RAG_API_KEY=                    # = ADIL_API_KEY on the rag-api side

# Postgres (shared with adil-rag-api)
DATABASE_URL=

# Cost cap kill switch (USD; outbound stops when exceeded for the calendar day)
WA_DAILY_COST_CAP_USD=50

# Per-phone rate limits
WA_RATE_PER_MINUTE=20
WA_RATE_PER_DAY=200

# Privacy notice URL shown on first contact
PRIVACY_NOTICE_URL=https://askadil.org/privacy

# /stats gate
OPERATOR_KEY=

# Operator pager (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MSENTRY_FEEDBACK_URL=
MSENTRY_FEEDBACK_SECRET=
