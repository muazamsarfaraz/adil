# TNA API (no auth needed)
TNA_BASE_URL=https://caselaw.nationalarchives.gov.uk

# Gemini
GEMINI_API_KEY=your_gemini_api_key
FILE_SEARCH_STORE_ID=fileSearchStores/your_store_id

# Database
DATABASE_URL=postgresql+asyncpg://uploader:uploader_dev@localhost:5434/document_uploader

# Backend Postgres URL (for rate_limit_cleanup cron). Defaults to DATABASE_URL if unset.
RAG_API_DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6381

# Auth
ADMIN_API_KEY=your_admin_api_key

# Service
PORT=8002
SERVICE_ROLE=api

# MSentry central health-bot inbox (optional)
MSENTRY_FEEDBACK_URL=
MSENTRY_FEEDBACK_SECRET=
MSENTRY_PROJECT=adil-document-uploader
