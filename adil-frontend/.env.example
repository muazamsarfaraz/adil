# =============================================================================
# Project Adil - Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: RAG API URL
# -----------------------------------------------------------------------------
# For local development:
RAG_API_URL=http://localhost:8000

# For production (Railway deployment):
# RAG_API_URL=https://your-adil-api.railway.app

# -----------------------------------------------------------------------------
# REQUIRED: API Key for RAG API Authentication
# -----------------------------------------------------------------------------
# Must match the ADIL_API_KEY set on the adil-rag-api service.
ADIL_API_KEY=adil_your_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Chainlit Configuration
# -----------------------------------------------------------------------------
# Host to bind to (use 0.0.0.0 for Docker/Railway)
CHAINLIT_HOST=0.0.0.0

# Port (Railway will inject $PORT automatically)
CHAINLIT_PORT=8080

